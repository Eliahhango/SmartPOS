{
  "name": "smartpos-backend",
  "version": "1.0.0",
  "description": "SmartPOS Supermarket System - Backend API",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:setup": "npx prisma db push && node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "railway:start": "npx prisma db push --accept-data-loss && node prisma/seed.js && node src/index.js"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "prisma": "5.22.0"
  }
}
