generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Branch {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(255)
  address       String?   @db.VarChar(500)
  phone         String?   @db.VarChar(50)
  isMainBranch  Boolean   @default(true) @map("is_main_branch")
  createdAt     DateTime  @default(now()) @map("created_at")
  users         User[]
  sales         Sale[]
  purchases     Purchase[]
  expenses      Expense[]
  stockMovements StockMovement[]

  @@map("branches")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(255)
  email     String    @unique @db.VarChar(255)
  phone     String?   @db.VarChar(50)
  password  String    @db.VarChar(255)
  role      Role      @default(cashier)
  branchId  Int?      @map("branch_id")
  branch    Branch?   @relation(fields: [branchId], references: [id])
  status    Status    @default(active)
  createdAt DateTime  @default(now()) @map("created_at")
  sales     Sale[]
  stockMovements StockMovement[]
  salesReturns SalesReturn[]

  @@map("users")
}

enum Role {
  admin
  manager
  cashier
  stock_officer
}

enum Status {
  active
  suspended
}

model Product {
  id            Int       @id @default(autoincrement())
  barcode       String?   @unique @db.VarChar(100)
  sku           String?   @unique @db.VarChar(100)
  name          String    @db.VarChar(255)
  categoryId    Int?      @map("category_id")
  category      Category? @relation(fields: [categoryId], references: [id])
  supplierId    Int?      @map("supplier_id")
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  costPrice     Decimal   @default(0) @map("cost_price") @db.Decimal(12, 2)
  sellingPrice  Decimal   @default(0) @map("selling_price") @db.Decimal(12, 2)
  taxClassId    Int?      @map("tax_class_id")
  taxClass      TaxRate?  @relation(fields: [taxClassId], references: [id])
  unit          String    @default("pcs") @db.VarChar(50)
  stockQuantity Int       @default(0) @map("stock_quantity")
  minimumStock  Int       @default(0) @map("minimum_stock")
  expiryDate    DateTime? @map("expiry_date")
  image         String?   @db.VarChar(500)
  status        ProductStatus @default(active)
  createdAt     DateTime  @default(now()) @map("created_at")
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  returnItems   ReturnItem[]
  stockMovements StockMovement[]

  @@map("products")
}

enum ProductStatus {
  active
  discontinued
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  description String?   @db.Text
  products    Product[]

  @@map("categories")
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(255)
  phone     String?   @db.VarChar(50)
  email     String?   @db.VarChar(255)
  address   String?   @db.VarChar(500)
  points    Int       @default(0)
  sales     Sale[]

  @@map("customers")
}

model Supplier {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  phone      String?   @db.VarChar(50)
  email      String?   @db.VarChar(255)
  address    String?   @db.VarChar(500)
  tinNumber  String?   @map("tin_number") @db.VarChar(100)
  products   Product[]
  purchases  Purchase[]

  @@map("suppliers")
}

model Sale {
  id         Int       @id @default(autoincrement())
  invoiceNo  String    @unique @map("invoice_no") @db.VarChar(50)
  customerId Int?      @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id])
  cashierId  Int       @map("cashier_id")
  cashier    User      @relation(fields: [cashierId], references: [id])
  branchId   Int?      @map("branch_id")
  branch     Branch?   @relation(fields: [branchId], references: [id])
  subtotal   Decimal   @db.Decimal(12, 2)
  discount   Decimal   @default(0) @db.Decimal(12, 2)
  taxTotal   Decimal   @default(0) @map("tax_total") @db.Decimal(12, 2)
  grandTotal Decimal   @map("grand_total") @db.Decimal(12, 2)
  status     SaleStatus @default(completed)
  createdAt  DateTime  @default(now()) @map("created_at")
  payments   Payment[]
  items      SaleItem[]
  returns    SalesReturn[]

  @@map("sales")
}

enum SaleStatus {
  completed
  suspended
  refunded
  partially_refunded
}

model Payment {
  id              Int       @id @default(autoincrement())
  saleId          Int       @map("sale_id")
  sale            Sale      @relation(fields: [saleId], references: [id])
  method          PaymentMethod
  amount          Decimal   @db.Decimal(12, 2)
  amountReceived  Decimal?  @map("amount_received") @db.Decimal(12, 2)
  changeGiven     Decimal?  @map("change_given") @db.Decimal(12, 2)
  referenceNo     String?   @map("reference_no") @db.VarChar(255)

  @@map("payments")
}

enum PaymentMethod {
  cash
  mobile_money
  card
  bank
}

model SaleItem {
  id              Int       @id @default(autoincrement())
  saleId          Int       @map("sale_id")
  sale            Sale      @relation(fields: [saleId], references: [id])
  productId       Int       @map("product_id")
  product         Product   @relation(fields: [productId], references: [id])
  quantity        Int
  price           Decimal   @db.Decimal(12, 2)
  taxRateApplied  Decimal   @default(0) @map("tax_rate_applied") @db.Decimal(5, 2)
  total           Decimal   @db.Decimal(12, 2)
  returnItems     ReturnItem[]

  @@map("sale_items")
}

model StockMovement {
  id            Int       @id @default(autoincrement())
  productId     Int       @map("product_id")
  product       Product   @relation(fields: [productId], references: [id])
  branchId      Int?      @map("branch_id")
  branch        Branch?   @relation(fields: [branchId], references: [id])
  changeQty     Int       @map("change_qty")
  reason        MovementReason
  referenceType String?   @map("reference_type") @db.VarChar(50)
  referenceId   Int?      @map("reference_id")
  userId        Int?      @map("user_id")
  user          User?     @relation(fields: [userId], references: [id])
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("stock_movements")
}

enum MovementReason {
  sale
  purchase
  adjustment
  return
  damage
  expiry
  transfer
}

model SalesReturn {
  id           Int          @id @default(autoincrement())
  saleId       Int          @map("sale_id")
  sale         Sale         @relation(fields: [saleId], references: [id])
  processedBy  Int          @map("processed_by")
  processor    User         @relation(fields: [processedBy], references: [id])
  refundMethod RefundMethod @map("refund_method")
  refundAmount Decimal      @map("refund_amount") @db.Decimal(12, 2)
  reason       String?      @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")
  items        ReturnItem[]

  @@map("sales_returns")
}

enum RefundMethod {
  cash
  store_credit
  original_payment_reversal
}

model ReturnItem {
  id            Int         @id @default(autoincrement())
  salesReturnId Int         @map("sales_return_id")
  salesReturn   SalesReturn @relation(fields: [salesReturnId], references: [id])
  saleItemId    Int         @map("sale_item_id")
  saleItem      SaleItem    @relation(fields: [saleItemId], references: [id])
  quantity      Int
  restocked     Boolean     @default(false)

  @@map("return_items")
}

model Purchase {
  id          Int            @id @default(autoincrement())
  supplierId  Int            @map("supplier_id")
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  branchId    Int?           @map("branch_id")
  branch      Branch?        @relation(fields: [branchId], references: [id])
  invoiceNo   String?        @map("invoice_no") @db.VarChar(100)
  status      PurchaseStatus @default(draft)
  totalAmount Decimal         @default(0) @map("total_amount") @db.Decimal(12, 2)
  date        DateTime       @default(now())
  items       PurchaseItem[]

  @@map("purchases")
}

enum PurchaseStatus {
  draft
  approved
  received
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int      @map("purchase_id")
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  productId  Int      @map("product_id")
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  costPrice  Decimal  @map("cost_price") @db.Decimal(12, 2)

  @@map("purchase_items")
}

model TaxRate {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  ratePercent Decimal  @map("rate_percent") @db.Decimal(5, 2)
  isActive    Boolean  @default(true) @map("is_active")
  products    Product[]

  @@map("tax_rates")
}

model Expense {
  id          Int      @id @default(autoincrement())
  expenseType String   @map("expense_type") @db.VarChar(255)
  amount      Decimal  @db.Decimal(12, 2)
  description String?  @db.Text
  branchId    Int?     @map("branch_id")
  branch      Branch?  @relation(fields: [branchId], references: [id])
  date        DateTime @default(now())

  @@map("expenses")
}
