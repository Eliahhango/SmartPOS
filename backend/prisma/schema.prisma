generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  address       String?
  phone         String?
  isMainBranch  Boolean   @default(true) @map("is_main_branch")
  createdAt     DateTime  @default(now()) @map("created_at")
  users         User[]
  sales         Sale[]
  purchases     Purchase[]
  expenses      Expense[]
  stockMovements StockMovement[]

  @@map("branches")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  phone     String?
  password  String
  role      String    @default("cashier")
  branchId  Int?      @map("branch_id")
  branch    Branch?   @relation(fields: [branchId], references: [id])
  status    String    @default("active")
  createdAt DateTime  @default(now()) @map("created_at")
  sales     Sale[]
  stockMovements StockMovement[]
  salesReturns SalesReturn[]
  auditLogs AuditLog[]

  @@map("users")
}

model Product {
  id            Int       @id @default(autoincrement())
  barcode       String?   @unique
  sku           String?   @unique
  name          String
  categoryId    Int?      @map("category_id")
  category      Category? @relation(fields: [categoryId], references: [id])
  supplierId    Int?      @map("supplier_id")
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  costPrice     Float     @default(0) @map("cost_price")
  sellingPrice  Float     @default(0) @map("selling_price")
  taxClassId    Int?      @map("tax_class_id")
  taxClass      TaxRate?  @relation(fields: [taxClassId], references: [id])
  unit          String    @default("pcs")
  stockQuantity Int       @default(0) @map("stock_quantity")
  minimumStock  Int       @default(0) @map("minimum_stock")
  reorderQuantity Int    @default(0) @map("reorder_quantity")
  batchNumber   String?   @map("batch_number")
  expiryDate    DateTime? @map("expiry_date")
  image         String?
  status        String    @default("active")
  createdAt     DateTime  @default(now()) @map("created_at")
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  stockMovements StockMovement[]

  @@map("products")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  products    Product[]

  @@map("categories")
}

model Customer {
  id          Int       @id @default(autoincrement())
  name        String
  phone       String?
  email       String?
  address     String?
  points      Int       @default(0)
  balance     Float     @default(0)   // positive = owes us, negative = credit balance
  creditLimit Float     @default(0)   // 0 = no credit allowed
  birthday    DateTime?
  sales       Sale[]
  payments    CustomerPayment[]

  @@map("customers")
}

model CustomerPayment {
  id          Int      @id @default(autoincrement())
  customerId  Int      @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id])
  amount      Float    // positive = payment received (reduces debt)
  method      String   // "cash", "bank", "mobile_money", etc.
  referenceNo String?  @map("reference_no")
  notes       String?
  saleId      Int?     @map("sale_id")  // linked sale if paying off a specific invoice
  sale        Sale?    @relation(fields: [saleId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("customer_payments")
}

model Supplier {
  id         Int       @id @default(autoincrement())
  name       String
  phone      String?
  email      String?
  address    String?
  tinNumber  String?   @map("tin_number")
  balance    Float     @default(0)
  products   Product[]
  purchases  Purchase[]
  payments   SupplierPayment[]

  @@map("suppliers")
}

model Sale {
  id         Int       @id @default(autoincrement())
  invoiceNo  String    @unique @map("invoice_no")
  customerId Int?      @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id])
  cashierId  Int       @map("cashier_id")
  cashier    User      @relation(fields: [cashierId], references: [id])
  branchId   Int?      @map("branch_id")
  branch     Branch?   @relation(fields: [branchId], references: [id])
  subtotal   Float
  discount   Float     @default(0)
  taxTotal   Float     @default(0) @map("tax_total")
  grandTotal Float     @map("grand_total")
  status     String    @default("completed")
  createdAt  DateTime  @default(now()) @map("created_at")
  payments   Payment[]
  customerPayments CustomerPayment[]
  items      SaleItem[]
  returns    SalesReturn[]

  @@map("sales")
}

model Payment {
  id              Int       @id @default(autoincrement())
  saleId          Int       @map("sale_id")
  sale            Sale      @relation(fields: [saleId], references: [id])
  method          String
  amount          Float
  amountReceived  Float?    @map("amount_received")
  changeGiven     Float?    @map("change_given")
  referenceNo     String?   @map("reference_no")

  @@map("payments")
}

model SaleItem {
  id              Int       @id @default(autoincrement())
  saleId          Int       @map("sale_id")
  sale            Sale      @relation(fields: [saleId], references: [id])
  productId       Int       @map("product_id")
  product         Product   @relation(fields: [productId], references: [id])
  quantity        Int
  price           Float
  taxRateApplied  Float     @default(0) @map("tax_rate_applied")
  total           Float
  returnItems     ReturnItem[]

  @@map("sale_items")
}

model StockMovement {
  id            Int       @id @default(autoincrement())
  productId     Int       @map("product_id")
  product       Product   @relation(fields: [productId], references: [id])
  branchId      Int?      @map("branch_id")
  branch        Branch?   @relation(fields: [branchId], references: [id])
  batchNumber   String?   @map("batch_number")
  changeQty     Int       @map("change_qty")
  reason        String
  referenceType String?   @map("reference_type")
  referenceId   Int?      @map("reference_id")
  userId        Int?      @map("user_id")
  user          User?     @relation(fields: [userId], references: [id])
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("stock_movements")
}

model SalesReturn {
  id           Int          @id @default(autoincrement())
  saleId       Int          @map("sale_id")
  sale         Sale         @relation(fields: [saleId], references: [id])
  processedBy  Int          @map("processed_by")
  processor    User         @relation(fields: [processedBy], references: [id])
  refundMethod String       @map("refund_method")
  refundAmount Float        @map("refund_amount")
  reason       String?
  createdAt    DateTime     @default(now()) @map("created_at")
  items        ReturnItem[]

  @@map("sales_returns")
}

model ReturnItem {
  id            Int         @id @default(autoincrement())
  salesReturnId Int         @map("sales_return_id")
  salesReturn   SalesReturn @relation(fields: [salesReturnId], references: [id])
  saleItemId    Int         @map("sale_item_id")
  saleItem      SaleItem    @relation(fields: [saleItemId], references: [id])
  quantity      Int
  restocked     Boolean     @default(false)

  @@map("return_items")
}

model Purchase {
  id          Int      @id @default(autoincrement())
  supplierId  Int      @map("supplier_id")
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  branchId    Int?     @map("branch_id")
  branch      Branch?  @relation(fields: [branchId], references: [id])
  invoiceNo   String?  @map("invoice_no")
  status      String   @default("draft")
  totalAmount Float    @default(0) @map("total_amount")
  date        DateTime @default(now())
  items       PurchaseItem[]
  supplierPayments SupplierPayment[]

  @@map("purchases")
}

model SupplierPayment {
  id          Int      @id @default(autoincrement())
  supplierId  Int      @map("supplier_id")
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  amount      Float
  method      String   // "cash", "bank", "mobile_money", "cheque"
  referenceNo String?  @map("reference_no")
  notes       String?
  purchaseId  Int?     @map("purchase_id")
  purchase    Purchase? @relation(fields: [purchaseId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("supplier_payments")
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int      @map("purchase_id")
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  productId  Int      @map("product_id")
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  costPrice  Float    @map("cost_price")

  @@map("purchase_items")
}

model TaxRate {
  id          Int      @id @default(autoincrement())
  name        String
  ratePercent Float    @map("rate_percent")
  isActive    Boolean  @default(true) @map("is_active")
  products    Product[]

  @@map("tax_rates")
}

model Expense {
  id          Int      @id @default(autoincrement())
  expenseType String   @map("expense_type")
  amount      Float
  description String?
  branchId    Int?     @map("branch_id")
  branch      Branch?  @relation(fields: [branchId], references: [id])
  date        DateTime @default(now())

  @@map("expenses")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // "create", "update", "delete", "login", "logout", "refund", "restore"
  entity    String   // "product", "sale", "purchase", "user", "customer", "supplier", "expense", "inventory"
  entityId  Int?     @map("entity_id")
  description String?
  metadata  String?  // JSON blob for before/after snapshots, price deltas, etc.
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
